{
    "table_metadata": {
        "table_name": "dbspl_sync",
        "description": "a long version of a month by month line by line internal income statement for DISH TV business unit, part of Echostar Corporation. Refernce this table for monthly totals of revenues, costs, capital expenses, and more.",
        "special_rules": ["Do not sum any derrived columns with columns it is derrived from"]
    },
    "columns": [
        {
            "name": "Metric",
            "description": "the specific line item of the income statement. refer to reference data if you're looking for specific line item names and what they correspond to.",
            "data_type": "String",
            "range_of_outcomes": "see line item descriptions",
            "formula": null
        },
        {
            "name": "Category",
            "description": "the scategory the line item falls into in the income statement",
            "data_type": "string",
            "range_of_outcomes": "revenue, cogs, variable costs, retention, costs, SAC, CapEx, SG&A, ratio",
            "formula": null
        },
        {
            "name": "Is_Derrived",
            "description": "an indicator column showing if a row is a function of other rows in the table. Never sum derrived columns with the columns they are derived from.",
            "data_type": "boolean",
            "range_of_outcomes": "True/False",
            "formula": null
        },
        {
            "name": "Year",
            "description": "the year the data is from",
            "data_type": "int",
            "range_of_outcomes": "2018 though curent year",
            "formula": null
        },
        {
            "name": "Month",
            "description": "the month the data is from",
            "data_type": "int",
            "range_of_outcomes": "1 through 12 corresponding to january-december",
            "formula": null
        },
        {
            "name": "Amount",
            "description": "the total of the given line item for that month",
            "data_type": "float",
            "range_of_outcomes": "positive or negative number",
            "formula": null
        }
    ],
